# AWS KMS / Secrets manager configurations
AWS_REGION=us-east-1
AWS_SECRET_NAME=datalog/prod/secrets

# Local LLM Variables
OLLAMA_API_BASE=http://localhost:11434
LLM_MODEL=ollama/llama3

# Note: In production, GITHUB_CLIENT_ID, GITHUB_CLIENT_SECRET, and SECRET_KEY are securely fetched from AWS Secrets Manager.
# The keys below will be used locally if AWS Secrets Manager is unavailable.
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID_HERE
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET_HERE
