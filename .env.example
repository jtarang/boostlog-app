# --- boostLog Environment Template ---
# Copy this file to .env.dev for local development or .env.production for prod.

# [DATABASE]
# For local dev use: postgresql://boostuser:boostpass@db:5432/boostlog
# For SQLite fallback use: sqlite:///./data/boostlog.db
DATABASE_URL=postgresql://boostuser:boostpass@db:5432/boostlog

# Postgres Credentials (used by the db container)
POSTGRES_USER=boostuser
POSTGRES_PASSWORD=boostpass
POSTGRES_DB=boostlog

# [AI AGENT]
# OLLAMA_API_BASE should point to the ollama service container in Docker
OLLAMA_API_BASE=http://ollama:11434
LLM_MODEL=ollama/llama3
OLLAMA_MODEL=llama3
OLLAMA_HOST=ollama:11434

# [AUTHENTICATION]
# Obtain these from GitHub Developer Settings
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
SECRET_KEY=generate_a_long_random_string_here

# [INFRASTRUCTURE]
# AWS configurations (optional for local)
AWS_REGION=us-east-1
AWS_SECRET_NAME=boostlog/env/secrets
# Set to 'true' to skip fetching secrets from AWS KMS/SecretsManager locally
SKIP_AWS_FETCH=true

# [CLOUDFLARE]
# Used for the cloudflared tunnel service in production
TUNNEL_TOKEN=your_cloudflare_tunnel_token
